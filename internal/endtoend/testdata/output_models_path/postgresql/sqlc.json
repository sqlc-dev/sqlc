{
  "version": "2",
  "sql": [
    {
      "schema": "schema.sql",
      "queries": "query.sql",
      "engine": "postgresql",
      "gen": {
        "go": {
          "out": "db",
          "package": "db",
          "emit_interface": true,
          "output_models_path": "model",
          "output_models_package": "model",
          "output_models_import": "github.com/sqlc-dev/sqlc/endtoend/output_models_path/postgresql/model"
        }
      }
    }
  ]
}
