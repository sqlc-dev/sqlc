{
  "version": "2",
  "sql": [
    {
      "schema": "postgresql/schema.sql",
      "queries": "postgresql/query.sql",
      "engine": "postgresql",
      "query_comments": {
        "enabled": true,
        "format": "marginalia"
      },
      "gen": {
        "json": {
          "out": "gen",
          "indent": "  ",
          "filename": "codegen.json"
        }
      }
    }
  ]
}
